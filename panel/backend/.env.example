# Copy to .env and fill with real values
PORT=4000
SESSION_SECRET=change-me
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://web-daemon.fus1on.host/auth/google/callback
DATABASE_URL=postgres://panel:panelpass@db:5432/panel
# Default admin credentials for local username/password login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
# Optionally provide a bcrypt hash instead of plain text
# ADMIN_PASSWORD_HASH=$2a$10$...
ADMIN_DISPLAY_NAME=Administrator
ADMIN_EMAIL=admin@example.com
